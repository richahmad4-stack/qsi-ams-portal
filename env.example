CI_ENVIRONMENT = production

app.baseURL = 'https://ams.qsi.example/'
app.forceGlobalSecureRequests = true

database.default.hostname = localhost
database.default.database = qsi_ams
database.default.username = qsi_ams_user
database.default.password = ''
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

security.csrfProtection = cookie
security.tokenRandomize = true
security.cookieName = csrf_token
security.expires = 7200
security.regenerate = true

session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
session.savePath = ci_sessions
session.cookieName = qsi_ams_session
session.expiration = 7200
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = true

encryption.key =

AMS_ADMIN_EMAIL = admin@qsi.example
AMS_ADMIN_PASSWORD =
AMS_ADMIN_NAME = 'QSI Administrator'
AMS_DEMO_PASSWORD =

AMS_EMAIL_NOTIFICATIONS_ENABLED = false
AMS_EMAIL_FROM = no-reply@example.com
AMS_EMAIL_FROM_NAME = 'QSI AMS'
email.protocol = smtp
email.SMTPHost =
email.SMTPUser =
email.SMTPPass =
email.SMTPPort = 587
email.SMTPCrypto = tls
email.mailType = text
